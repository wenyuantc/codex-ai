{
  "name": "codex-ai",
  "private": true,
  "version": "0.3.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && npm run build:web",
    "build:web": "node --max-old-space-size=4096 ./node_modules/vite/bin/vite.js build",
    "preview": "vite preview",
    "bump-version": "node scripts/bump-version.mjs",
    "tauri": "tauri",
    "tauri:dev": "tauri dev",
    "tauri:dmg": "tauri build --bundles dmg",
    "tauri:dmg:no-sign": "tauri build --bundles dmg --no-sign",
    "tauri:linux": "tauri build --bundles appimage,deb,rpm",
    "tauri:linux:appimage": "tauri build --bundles appimage",
    "tauri:linux:deb": "tauri build --bundles deb",
    "tauri:linux:rpm": "tauri build --bundles rpm",
    "tauri:windows": "tauri build --bundles nsis,msi",
    "tauri:windows:nsis": "tauri build --bundles nsis",
    "tauri:windows:msi": "tauri build --bundles msi"
  },
  "dependencies": {
    "@base-ui/react": "^1.3.0",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@fontsource-variable/geist": "^5.2.8",
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-dialog": "^2.7.0",
    "@tauri-apps/plugin-opener": "^2",
    "@tauri-apps/plugin-shell": "^2.3.5",
    "@tauri-apps/plugin-sql": "^2.4.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.8.0",
    "monaco-editor": "^0.55.1",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-router-dom": "^7.14.0",
    "shadcn": "^4.2.0",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.2",
    "@tauri-apps/cli": "^2",
    "@types/node": "^25.6.0",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^4.6.0",
    "simple-git": "^3.28.0",
    "tailwindcss": "^4.2.2",
    "typescript": "~5.8.3",
    "vite": "^7.0.4"
  }
