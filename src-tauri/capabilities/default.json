{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "opener:default",
    "sql:default",
    "sql:allow-execute",
    "sql:allow-select",
    "dialog:default",
    {
      "identifier": "shell:allow-spawn",
      "allow": [
        {
          "name": "codex-cli",
          "cmd": "codex",
          "args": true,
          "sidecar": false
        }
      ]
    },
    "shell:allow-kill",
    "shell:allow-stdin-write",
    "shell:allow-execute"
  ]
}
